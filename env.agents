# ═══════════════════════════════════════════════════════════════════════
# UC-2 / UC-3 / UC-4 Agent LLM Configuration
# Append these lines to your existing .env file.
#
# Resolution order per agent (mirrors llm_gateway.py behaviour):
#   1. {AGENT}_{PURPOSE}_MODEL   ← most specific, wins first
#   2. {AGENT}_MODEL             ← agent-wide override
#   3. CHAT_MODEL / EMBEDDING_MODEL ← global fallback (already in your .env)
#
# Provider resolution per agent:
#   1. {AGENT}_{PURPOSE}_PROVIDER
#   2. {AGENT}_LLM_PROVIDER
#   3. {AGENT}_PROVIDER
#   4. LLM_PROVIDER              ← global fallback (already in your .env)
#
# To switch a single agent to OpenAI while keeping everything else on Ollama:
#   TRUE_FAILURE_RCA_V1_CHAT_PROVIDER=openai
#   TRUE_FAILURE_RCA_V1_CHAT_MODEL=gpt-4o
# ═══════════════════════════════════════════════════════════════════════


# ── UC-2 Risk Scorer ────────────────────────────────────────────────────
# Reads git diff + Jira AC text, scores business criticality.
# Needs good instruction-following — qwen2.5:14b or llama3:8b both work.
RISK_SCORER_V1_CHAT_MODEL=qwen2.5:14b-instruct
RISK_SCORER_V1_EMBEDDING_MODEL=mxbai-embed-large:latest
RISK_SCORER_V1_CHAT_PROVIDER=ollama
# RISK_SCORER_V1_CHAT_PROVIDER=openai
# RISK_SCORER_V1_CHAT_MODEL=gpt-4o-mini


# ── UC-3 Classifier ─────────────────────────────────────────────────────
# True vs false failure verdict — embedding cluster match + LLM arbitration.
# llama3:8b is fast enough; bump to 14b if verdict accuracy is low.
CLASSIFIER_V1_CHAT_MODEL=llama3:8b
CLASSIFIER_V1_EMBEDDING_MODEL=mxbai-embed-large:latest
CLASSIFIER_V1_CHAT_PROVIDER=ollama


# ── UC-3 True Failure RCA ───────────────────────────────────────────────
# Reads stack trace + git blame → detailed root cause + Jira bug body.
# This is the most reasoning-heavy call — use the strongest model available.
TRUE_FAILURE_RCA_V1_CHAT_MODEL=qwen2.5:14b-instruct
TRUE_FAILURE_RCA_V1_CHAT_PROVIDER=ollama
# TRUE_FAILURE_RCA_V1_CHAT_PROVIDER=openai
# TRUE_FAILURE_RCA_V1_CHAT_MODEL=gpt-4o


# ── UC-3 False Failure RCA ──────────────────────────────────────────────
# Sub-classifies env/selector/timeout issues → routes to spec_fixer.
# Lighter task — llama3:8b is sufficient.
FALSE_FAILURE_RCA_V1_CHAT_MODEL=llama3:8b
FALSE_FAILURE_RCA_V1_CHAT_PROVIDER=ollama


# ── UC-4 Selector Healer ────────────────────────────────────────────────
# Embedding: find nearest element in updated Qdrant snapshot.
# Chat: LLM fallback when embedding confidence is low.
SELECTOR_HEALER_V1_CHAT_MODEL=llama3:8b
SELECTOR_HEALER_V1_EMBEDDING_MODEL=mxbai-embed-large:latest
SELECTOR_HEALER_V1_CHAT_PROVIDER=ollama


# ═══════════════════════════════════════════════════════════════════════
# Quick-switch examples
# ───────────────────────────────────────────────────────────────────────
# Switch ALL UC agents to Claude at once (override per-agent providers):
#   LLM_PROVIDER=claude
#   ANTHROPIC_API_KEY=sk-ant-...
#   CHAT_MODEL=claude-sonnet-4-6          ← global fallback model
#
# Keep Ollama for everything EXCEPT true_failure_rca (use Claude for RCA):
#   TRUE_FAILURE_RCA_V1_CHAT_PROVIDER=claude
#   TRUE_FAILURE_RCA_V1_CHAT_MODEL=claude-sonnet-4-6
#   ANTHROPIC_API_KEY=sk-ant-...
#
# Use Gemini for classifier only:
#   CLASSIFIER_V1_CHAT_PROVIDER=gemini
#   CLASSIFIER_V1_CHAT_MODEL=gemini-1.5-flash
#   GEMINI_API_KEY=AIza...
# ═══════════════════════════════════════════════════════════════════════
